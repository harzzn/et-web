# Template for deploy/deploy.env (gitignored). Copy, fill in, and release.sh /
# box-setup.sh will source it. In production these values + secrets come from
# the private helja.la repo and its chamber/SSM vault instead - keep the real
# deploy.env out of git (it's already in .gitignore).
#
#   cp deploy/deploy.env.example deploy/deploy.env   # then edit

# --- box + client (release.sh) ---
BOX_IP=                              # origin box IP (SECRET - hidden behind Cloudflare)
ASSET_BASE=https://assets.example.com   # R2 custom-domain base for paks
R2_REMOTE=r2:et-assets               # rclone remote:bucket
# WS_URL=                            # leave empty -> same-origin wss://<host>/net
# GAME_SERVER=127.0.0.1:27960        # engine-side connect token

# --- R2 upload creds (release.sh; prefer chamber/env over committing) ---
# RCLONE_CONFIG_R2_TYPE=s3
# RCLONE_CONFIG_R2_PROVIDER=Cloudflare
# RCLONE_CONFIG_R2_ACCESS_KEY_ID=
# RCLONE_CONFIG_R2_SECRET_ACCESS_KEY=
# RCLONE_CONFIG_R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# RCLONE_CONFIG_R2_NO_CHECK_BUCKET=true

# --- box-setup.sh (server provisioning) ---
ET_HOST=et.example.com               # vhost Caddy serves
# RCONPASSWORD=                      # SECRET - server rcon
# ETLEGACY_SHA=                      # pin to the commit the wasm client built from
# SV_HOSTNAME=ET Web
# SV_MAXCLIENTS=24
# START_MAP=radar
