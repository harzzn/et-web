# Caddy config for the ET:Legacy web port — plain local HTTP origin.
#
# Public TLS is handled OUTSIDE this repo by whatever fronts the box
# (Cloudflare Tunnel, a reverse proxy, etc.). Caddy only serves the shell +
# the /net WebSocket on localhost:80; the fronting layer maps a public
# hostname to it. No certs, no open inbound ports here.
#
# For a direct-public single box instead (no fronting layer), replace ":80"
# with your hostname so Caddy auto-provisions TLS (needs port 80/443 reachable).

:80 {
	root * /opt/et-web/web
	file_server
	encode zstd gzip

	# game socket: same-origin /net -> ws<->udp proxy
	# (matches net_web_tunnel.c's same-origin default)
	handle /net {
		reverse_proxy 127.0.0.1:27970
	}

	# big immutable artifacts cache hard; manifest + js loader revalidate
	@big path *.pk3 *.wasm
	header @big Cache-Control "public, max-age=604800"
	header /manifest.json Cache-Control "no-cache"
	header /etl.js Cache-Control "no-cache"
}
